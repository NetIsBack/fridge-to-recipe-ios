// Firestore Security Rules for Collaborative Shopping Lists
// Copy these rules to your Firebase Console -> Firestore Database -> Rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection - users can only read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Shopping lists - allow reading for invite code queries and collaborators
    match /shopping_lists/{listId} {
      // Allow reading any list if user is authenticated (needed for invite code queries)
      allow read: if request.auth != null;
      
      // Allow writing only if user is a collaborator or creating their own list
      allow write: if request.auth != null && (
        (resource == null && request.auth.uid == request.resource.data.ownerId) ||
        (resource != null && request.auth.uid in resource.data.collaborators.keys()) ||
        (resource != null && request.auth.uid in request.resource.data.collaborators.keys())
      );
      
      // Allow creating new lists
      allow create: if request.auth != null && 
        request.auth.uid == request.resource.data.ownerId;
        
      // Items subcollection
      match /items/{itemId} {
        allow read, write: if request.auth != null && 
          request.auth.uid in get(/databases/$(database)/documents/shopping_lists/$(listId)).data.collaborators.keys();
      }
      
      // Activity log subcollection
      match /activity_log/{activityId} {
        allow read, write: if request.auth != null && 
          request.auth.uid in get(/databases/$(database)/documents/shopping_lists/$(listId)).data.collaborators.keys();
      }
    }
  }
}
